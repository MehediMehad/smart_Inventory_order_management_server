generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id       String         @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  image    String
  email    String         @unique
  phone    String
  password String
  role     UserRoleEnum
  status   UserStatusEnum @default(DEACTIVATE)

  fcmTokens   String[] // Push 🔔 multiple device support
  isVerified  Boolean   @default(false)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Notification Relations
  notificationsSent     Notification[] @relation("sender")
  notificationsReceived Notification[] @relation("receiver")
  orders                Order[]
  activityLogs          ActivityLog[]

  @@map("users")
}

// Product & Categories
model Category {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("categories")
}

model Product {
  id                String        @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  category          Category      @relation(fields: [categoryId], references: [id])
  categoryId        String        @db.ObjectId
  price             Float
  stockQuantity     Int
  minStockThreshold Int
  status            ProductStatus @default(ACTIVE)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  orderItems        OrderItem[]
  restockQueueItem  RestockQueue?

  @@index([categoryId])
  @@map("products")
}

enum ProductStatus {
  ACTIVE
  OUT_OF_STOCK
}

// Orders & Order Items
model Order {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId
  customerName String
  totalPrice   Float
  status       OrderStatus @default(PENDING)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         User        @relation(fields: [userId], references: [id])
  userId       String      @db.ObjectId
  items        OrderItem[]

  @@index([status])
  @@index([createdAt])
  @@index([customerName])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   String  @db.ObjectId
  product   Product @relation(fields: [productId], references: [id])
  productId String  @db.ObjectId
  quantity  Int
  price     Float

  @@index([productId])
  @@index([orderId])
  @@map("orderItems")
}

// Order Status Enum
enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

// Restock Queue (Low Stock Management)
model RestockQueue {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  product   Product  @relation(fields: [productId], references: [id])
  productId String   @unique @db.ObjectId
  priority  Priority @default(MEDIUM)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("restockQueue")
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

// Activity Log
model ActivityLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  message   String
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @db.ObjectId
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("activityLogs")
}

model Notification {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Who sent the notification (null = system)
  senderId String? @db.ObjectId
  sender   User?   @relation("sender", fields: [senderId], references: [id])

  // Who received the notification
  receiverId String @db.ObjectId
  receiver   User   @relation("receiver", fields: [receiverId], references: [id])

  // Content
  title String
  body  String
  data  Json? // Additional data payload

  // 🔥 Generic Type
  type NotificationTypeEnum @default(NOTIFY) // MESSAGE , FRIEND_REQUEST, SYSTEM_ALERT, NOTIFY

  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([receiverId, isRead])
  @@index([type])
  @@map("notifications")
}

enum NotificationTypeEnum {
  NOTIFY
  SYSTEM_ALERT
}

// OTP Storage Database
model Otp {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  email     String
  code      String
  type      OtpTypeEnum //  VERIFY_EMAIL, RESET_PASSWORD, VERIFY_PHONE,
  createdAt DateTime    @default(now())
  expiresAt DateTime

  @@unique([email, code, type])
  @@index([email, type, expiresAt])
  @@map("opts")
}

// Enums
enum OtpTypeEnum {
  LOGIN
  FORGOT_PASSWORD
  VERIFY_EMAIL
  RESET_PASSWORD
  VERIFY_PHONE
  VERIFY_USER
}

enum UserRoleEnum {
  USER
  MANAGER
  ADMIN
}

enum UserStatusEnum {
  DEACTIVATE
  ACTIVE
  BLOCKED
}
